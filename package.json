{
  "name": "agent-skills",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.ts",
    "validate": "node scripts/validate.ts",
    "render:example": "node scripts/render_discovery.ts examples/deployment-visibility",
    "check:example": "node scripts/render_discovery.ts examples/deployment-visibility --check",
    "check": "npm run format:check && npm run typecheck && npm test && npm run validate && npm run check:example"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "oxfmt": "^0.58.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=24"
  }
}
